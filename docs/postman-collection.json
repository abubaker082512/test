          "host": ["{{baseUrl}}"],
          "path": ["api", "rapid", "getAllProviders"]
        }
      }
    },
    {
      "name": "Get All Games By Provider",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/rapid/getAllGamesByProvider?provider=SPRIBE",
          "host": ["{{baseUrl}}"],
          "path": ["api", "rapid", "getAllGamesByProvider"],
          "query": [{"key": "provider", "value": "SPRIBE"}]
        }
      }
    }
  ],
